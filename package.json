{
  "name": "discordbot",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "node --env-file=.env.development index.js | pino-pretty -i pid,hostname -t 'yyyy-mm-dd HH:MM:ss'",
    "start": "NODE_ENV=production node --env-file=.env.production index.js | pino-pretty -i pid,hostname -t 'yyyy-mm-dd HH:MM:ss' -L error",
    "deploy": "node --env-file=.env.production deploy-commands.js | pino-pretty -i pid,hostname -t 'yyyy-mm-dd HH:MM:ss'",
    "deploy-dev": "node --env-file=.env.development deploy-commands.js | pino-pretty -i pid,hostname -t 'yyyy-mm-dd HH:MM:ss'"
  },
  "dependencies": {
    "discord.js": "^14.26.3",
    "pino": "^10.3.1"
  }
}
